# Production Environment Configuration
# Copy to .env for production deployment

# CORS Origins (update with your Vercel domain)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-backend-domain.com

# Database (use PostgreSQL or cloud SQLite for production)
# Example: postgresql://user:password@host:5432/carbon_tracker
DATABASE_URL=sqlite:///./carbon_tracker.db
